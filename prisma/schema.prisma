generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id               String   @id @default(cuid())
  reference        String   @unique
  ticketType       String
  visitDate        DateTime
  adults           Int
  children         Int      @default(0)
  totalAmount      Float
  currency         String   @default("EUR")
  customerName     String
  customerEmail    String
  customerPhone    String?
  customerCountry  String?
  locale           String
  specialRequests  String?
  status           String   @default("pending")
  paymentProvider  String   @default("mock")
  paymentSessionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
}

model PageView {
  id             String   @id @default(cuid())
  sessionId      String
  visitorId      String
  path           String
  locale         String
  referrer       String?
  referrerDomain String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  country        String?
  city           String?
  device         String?
  browser        String?
  os             String?
  ipHash         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([country])
  @@index([referrerDomain])
  @@index([visitorId])
}

model Event {
  id        String   @id @default(cuid())
  sessionId String
  visitorId String
  name      String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
  @@index([visitorId])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String
  locale    String
  scope     String   @default("general")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, scope])
  @@index([category])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String
  locale      String
  excerpt     String?
  content     String?
  coverImage         String?
  coverImageAlt      String?
  coverImagePosition String?
  category           String
  tags        String?
  seoTitle    String?
  seoDesc     String?
  ogImage     String?
  author      String   @default("Bahia Palace Team")
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, category])
  @@index([published])
}

model SafetyTip {
  id        String   @id @default(cuid())
  title     String
  body      String
  icon      String   @default("warning")
  published Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  locale    String?
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id         String   @id @default(cuid())
  url        String
  altText    String
  title      String
  caption    String?
  seoKeyword String?
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, order])
}

model Review {
  id         String   @id @default(cuid())
  authorName String
  authorImg  String?
  country    String?
  rating     Int      @default(5)
  body       String
  locale     String
  published  Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([locale, published])
}

model Lead {
  id          String   @id @default(cuid())
  email       String?
  name        String?
  ticketType  String
  locale      String
  sourcePage  String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  device      String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model TicketType {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameEn        String
  nameFr        String
  nameIt        String
  nameDe        String
  nameEs        String
  descEn        String
  descFr        String
  descIt        String
  descDe        String
  descEs        String
  priceAdult    Float
  priceChild    Float    @default(0)
  durationMins  Int      @default(60)
  maxPerDay     Int?
  available     Boolean  @default(true)
  images        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
